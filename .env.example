# ============================================================
#  PLANTILLA DE VARIABLES DE ENTORNO - Bot Ferrum
#  Copia este archivo como ".env" y completa tus datos.
#  NUNCA subas el archivo .env a un repositorio público.
# ============================================================

# Credenciales de acceso a la plataforma Ferrum
FERRUM_USERNAME=tu_usuario_aqui
FERRUM_PASSWORD=tu_contraseña_aqui

# ──────────────────────────────────────────────
# SOPORTE MULTI-PERFIL (opcional)
# Si usas múltiples cuentas, agrega las credenciales así:
# ──────────────────────────────────────────────
# FERRUM_USER_ESTUDIANTE2_USERNAME=usuario2
# FERRUM_USER_ESTUDIANTE2_PASSWORD=contraseña2
